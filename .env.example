# ─────────────────────────────────────────────────────────────────────────────
# DUDING.AI — Environment Variables
# Copy this file to .env for local dev.
# Set these directly in Railway for production.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev:  leave unset (defaults to sqlite:///duding.db in project folder)
# Railway:    sqlite:////data/duding.db  (volume must be mounted at /data)
DATABASE_URL=sqlite:///duding.db

# ── Admin login ───────────────────────────────────────────────────────────────
ADMIN_EMAIL=duding@duding.ai
ADMIN_PASSWORD=your-strong-password-here

# ── Session secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-this-to-a-long-random-string

# ── Email sending via Resend (https://resend.com) ────────────────────────────
# 1. Sign up at resend.com (free tier: 3,000 emails/month)
# 2. Verify your domain (duding.ai) under Domains
# 3. Create an API key under API Keys
RESEND_API_KEY=re_...
# The verified "from" address — must match your verified Resend domain
RESEND_FROM=Tommy <tommy@duding.ai>
FROM_NAME=Tommy
ADMIN_NOTIFY_EMAIL=duding@duding.ai

# ── Gmail credentials (IMAP only — for reading replies) ──────────────────────
# Still needed so the outreach engine can check for replies in your Gmail inbox.
# Outbound sending goes through Resend, not SMTP.
SMTP_USER=duding@duding.ai
SMTP_PASSWORD=your-16-char-app-password

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# After Railway deploys, set these to your Railway app URL:
STRIPE_SUCCESS_URL=https://your-app.up.railway.app/builder/success
STRIPE_CANCEL_URL=https://your-app.up.railway.app/builder

# ── Outreach engine ───────────────────────────────────────────────────────────
# Your Calendly booking link (sent to positive replies automatically)
CALENDLY_LINK=https://calendly.com/your-link

# SMS alerts — email-to-SMS gateway for your carrier:
#   AT&T:      number@txt.att.net
#   Verizon:   number@vtext.com
#   T-Mobile:  number@tmomail.net
#   Sprint:    number@messaging.sprintpcs.com
# Leave blank to disable SMS alerts
TOMMY_SMS_EMAIL=

# ── PDF generation (optional — leave blank to disable) ───────────────────────
# wkhtmltopdf is not available on Railway — quote PDF export will be disabled
WKHTMLTOPDF_PATH=
